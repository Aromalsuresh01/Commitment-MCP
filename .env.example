# Claude API Key (required for extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Gmail API Credentials (required for sync)
# You will need to create a project in Google Cloud Console and download credentials.json
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret

# Server Port (if running in SSE mode)
PORT=3000
